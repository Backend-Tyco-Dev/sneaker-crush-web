# GraphQL API proxy target (dev server). Used when running `npm run dev`.
# Default if unset: http://45.77.217.138:3000
GRAPHQL_TARGET=http://localhost:3000

# Dev server host and port (optional; can be overwritten by CLI)
# HOST=localhost
# PORT=8080

# Deploy / CI (see .gitlab-ci.yml and ecosystem.config.js)
# TARGET_SERVER_HOST=
# TARGET_SERVER_USER=
# SSH_PRIVATE_KEY=
